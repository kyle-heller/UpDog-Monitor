# Database connection (default works with docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/updog_dev

# Discord webhook for alerts (optional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-here

# Azure Monitor (optional - enables OpenTelemetry export to Log Analytics)
# APPLICATIONINSIGHTS_CONNECTION_STRING=
